# Локальная конфигурация LawRAG
# Скопируйте этот файл в .env и настройте под свои нужды

# LLM Provider настройки (локальные провайдеры)
# Варианты: 'ollama' или 'finetuned'
LLM_PROVIDER_TYPE=ollama

# Модель по умолчанию
# Для Ollama: llama3.2, llama3.1, mistral, qwen2.5 и др.
# Для Fine-tuned: gemma-3n-4b-kazakh-law (автоматически)
LLM_MODEL=llama3.2

# Ollama настройки (если LLM_PROVIDER_TYPE=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Fine-tuned модель настройки (если LLM_PROVIDER_TYPE=finetuned)
FINETUNED_API_URL=http://localhost:8000

# Flask настройки
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Настройки модели эмбеддингов (для поиска по документам)
# Модели автоматически кэшируются в ~/.cache/huggingface/hub после первой загрузки
# Для полностью офлайн работы: предварительно загрузите модель один раз с интернетом

# Основная модель (многоязычная, лучше для русского/казахского)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Альтернативная модель (легче, быстрее, но только английский)
# EMBEDDING_MODEL_OFFLINE=all-MiniLM-L6-v2

# Локальный путь к модели (если модель уже скачана локально)
# EMBEDDING_MODEL_LOCAL_PATH=/path/to/local/model
